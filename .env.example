# MCP server auth (optional — leave empty to disable auth)
MCP_BEARER_TOKEN=

# ngrok (free static domain from https://dashboard.ngrok.com/domains)
NGROK_AUTHTOKEN=
NGROK_DOMAIN=your-name-here.ngrok-free.dev

# ERC-8004 Registration (Ethereum Sepolia)
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
WALLET_ADDRESS=
SIGNER_PVT_KEY=
PINATA_JWT=

# Fake rover simulator (optional — defaults to http://localhost:8080)
FAKEROVER_URL=http://localhost:8080

# Stripe payment integration (optional — requires uv sync --extra marketplace)
# Get these from https://dashboard.stripe.com/apikeys and https://dashboard.stripe.com/webhooks
# Leave empty to disable Stripe; robots can still receive USDC payments directly on-chain.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Operator's Stripe Connect Express account ID (acct_...) for destination charges
# Obtain from the marketplace platform after completing Stripe Express onboarding
STRIPE_CONNECT_ACCOUNT_ID=
